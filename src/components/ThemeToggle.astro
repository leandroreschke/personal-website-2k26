---
// ThemeToggle.astro
---

<button
  type="button"
  class="custom-button theme-toggle-button"
  aria-label="Toggle color theme"
  aria-pressed="false"
  data-theme-toggle
>
  <!-- Sun Icon -->
  <svg
    class="sun"
    xmlns="http://www.w3.org/2000/svg"
    width="16"
    height="16"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="2"
    stroke-linecap="round"
    stroke-linejoin="round"
  >
    <circle cx="12" cy="12" r="4"></circle>
    <path d="M12 2v2"></path>
    <path d="M12 20v2"></path>
    <path d="m4.93 4.93 1.41 1.41"></path>
    <path d="m17.66 17.66 1.41 1.41"></path>
    <path d="M2 12h2"></path>
    <path d="M22 12h2"></path>
    <path d="m6.34 17.66-1.41 1.41"></path>
    <path d="m19.07 4.93-1.41 1.41"></path>
  </svg>
  <!-- Moon Icon -->
  <svg
    class="moon"
    xmlns="http://www.w3.org/2000/svg"
    width="16"
    height="16"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="2"
    stroke-linecap="round"
    stroke-linejoin="round"
  >
    <path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"></path>
  </svg>
</button>

<style>
  .theme-toggle-button {
    user-select: none;
    appearance: none;
    -webkit-appearance: none;
  }
</style>

<script>
  const themeToggle = document.querySelector("[data-theme-toggle]");
  const themeInput = document.querySelector(
    "#state-theme-dark",
  ) as HTMLInputElement | null;
  const prefersReducedMotion = window.matchMedia(
    "(prefers-reduced-motion: reduce)",
  );

  if (themeToggle instanceof HTMLButtonElement && themeInput) {
    const syncPressedState = () => {
      themeToggle.setAttribute("aria-pressed", String(themeInput.checked));
    };

    const setTheme = (nextChecked: boolean) => {
      themeInput.checked = nextChecked;
      syncPressedState();
    };

    const getToggleOrigin = (event: MouseEvent | KeyboardEvent) => {
      const rect = themeToggle.getBoundingClientRect();

      if (event instanceof MouseEvent) {
        return { x: event.clientX, y: event.clientY };
      }

      return {
        x: rect.left + rect.width / 2,
        y: rect.top + rect.height / 2,
      };
    };

    const animateThemeChange = async (event: MouseEvent | KeyboardEvent) => {
      const nextChecked = !themeInput.checked;
      const { x, y } = getToggleOrigin(event);
      const endRadius = Math.hypot(
        Math.max(x, window.innerWidth - x),
        Math.max(y, window.innerHeight - y),
      );

      if (
        typeof document.startViewTransition !== "function" ||
        prefersReducedMotion.matches
      ) {
        setTheme(nextChecked);
        return;
      }

      document.documentElement.classList.add("theme-transitioning");

      const transition = document.startViewTransition(() => {
        setTheme(nextChecked);
      });

      try {
        await transition.ready;
        document.documentElement.animate(
          {
            clipPath: [
              `circle(0px at ${x}px ${y}px)`,
              `circle(${endRadius}px at ${x}px ${y}px)`,
            ],
          },
          {
            duration: 1100,
            easing: "cubic-bezier(0.4, 0, 0.2, 1)",
            pseudoElement: "::view-transition-new(root)",
          },
        );
      } finally {
        transition.finished.finally(() => {
          document.documentElement.classList.remove("theme-transitioning");
        });
      }
    };

    syncPressedState();

    themeToggle.addEventListener("click", (event) => {
      void animateThemeChange(event);
    });

    themeToggle.addEventListener("keydown", (event) => {
      if (event.key !== "Enter" && event.key !== " ") {
        return;
      }

      event.preventDefault();
      void animateThemeChange(event);
    });
  }
</script>
