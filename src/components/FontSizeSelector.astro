<div
  class="font-size-selector"
  data-font-size-selector
  style="display: flex; gap: 0.5rem; align-items: center;"
>
  <label
    for="state-font-normal"
    class="custom-button btn-font-normal"
    aria-label="Normal Font Size"
    style="font-size: 12px;">A</label
  >
  <label
    for="state-font-big"
    class="custom-button btn-font-big"
    aria-label="Big Font Size"
    style="font-size: 16px;">A</label
  >
</div>

<script>
  const fontSizeSelector = document.querySelector("[data-font-size-selector]");
  const fontSizeInputs = document.querySelectorAll(
    'input[name="font-size"]',
  ) as NodeListOf<HTMLInputElement>;

  if (fontSizeSelector instanceof HTMLDivElement && fontSizeInputs.length > 0) {
    const html = document.documentElement;
    const motionClasses = ["font-size-grow", "font-size-shrink"];
    const transitionClasses = ["font-size-transitioning"];
    let motionTimeout = 0;

    const triggerMotion = (className: string) => {
      window.clearTimeout(motionTimeout);
      html.classList.remove(...motionClasses, ...transitionClasses);
      void html.offsetWidth;
      html.classList.add(...transitionClasses);
      html.classList.add(className);
      motionTimeout = window.setTimeout(() => {
        html.classList.remove(...transitionClasses);
        html.classList.remove(className);
      }, 320);
    };

    fontSizeInputs.forEach((input) => {
      input.addEventListener("change", (event) => {
        const target = event.currentTarget;

        if (!(target instanceof HTMLInputElement) || !target.checked) {
          return;
        }

        triggerMotion(
          target.id === "state-font-big"
            ? "font-size-grow"
            : "font-size-shrink",
        );
      });
    });
  }
</script>
